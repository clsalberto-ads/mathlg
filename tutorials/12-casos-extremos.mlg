# ======================================================================
# Tutorial 12: Casos Extremos (Edge Cases)
# ======================================================================
#
# OBJETIVO: Conhecer situações limite e comportamentos especiais.
#
# CONCEITOS:
#   - Operações com zero
#   - Números negativos
#   - Números grandes
#   - Resultados decimais
#   - Parênteses aninhados
#   - Funções matemáticas aninhadas
#   - Strings vazias
#   - Múltiplos espaços (são ignorados)
#   - Expressões unárias com menos
#
# COMO USAR:
#   $ mathlg tutorials/12-casos-extremos.mlg
# ======================================================================

# ------------------------------------------------------------------
# 1. OPERAÇÕES COM ZERO
# ------------------------------------------------------------------
mostre "=== 1. OPERACOES COM ZERO ==="
mostre 0 + 0                       # 0
mostre 0 * 100                     # 0
mostre 100 * 0                     # 0
mostre 0 / 5                       # 0.0
mostre 5 + 0                       # 5
mostre 5 - 0                       # 5

# ------------------------------------------------------------------
# 2. NÚMEROS NEGATIVOS
# ------------------------------------------------------------------
mostre "=== 2. NUMEROS NEGATIVOS ==="
mostre -5                          # -5
mostre -10 + 3                     # -7
mostre -5 * -3                     # 15
mostre -10 / 2                     # -5.0
mostre valor absoluto de -42       # 42

# ------------------------------------------------------------------
# 3. NÚMEROS GRANDES
# ------------------------------------------------------------------
mostre "=== 3. NUMEROS GRANDES ==="
mostre 999999999                   # 999999999
mostre 1000000 * 1000000           # 1000000000000

# ------------------------------------------------------------------
# 4. RESULTADOS DECIMAIS
# ------------------------------------------------------------------
mostre "=== 4. DECIMAIS ==="
mostre 10 / 3                      # 3.333...
mostre 7 * 0.5                     # 3.5
mostre 10 + 0.5                    # 10.5

# ------------------------------------------------------------------
# 5. PARÊNTESES ANINHADOS
# ------------------------------------------------------------------
mostre "=== 5. PARENTESES ==="
mostre 2 + 3 * 4                   # 14
mostre (2 + 3) * 4                 # 20
mostre ((2 + 3) * 4) - 1          # 19
mostre (10 - (2 + 3)) * 2          # 10

# ------------------------------------------------------------------
# 6. FUNÇÕES ANINHADAS
# ------------------------------------------------------------------
mostre "=== 6. FUNCOES ANINHADAS ==="
mostre raiz de (4 + 5)             # 3.0 = sqrt(9)
mostre valor absoluto de (-(5+3))  # 8 = abs(-8)
mostre raiz de (potencia de 3 elevado a 2)  # 3.0 = sqrt(9)

# ------------------------------------------------------------------
# 7. STRINGS
# ------------------------------------------------------------------
mostre "=== 7. STRINGS ==="
vazia = ""
mostre vazia                       # (vazio)
texto = "MathLg v0.1"
mostre texto                       # MathLg v0.1

# ------------------------------------------------------------------
# 8. MÚLTIPLOS ESPAÇOS
# ------------------------------------------------------------------
mostre "=== 8. ESPACOS EXTRAS ==="
mostre 2       +       3           # 5 (espacos sao ignorados)

# ------------------------------------------------------------------
# 9. ATRIBUIÇÃO ENCADEADA
# ------------------------------------------------------------------
mostre "=== 9. ATRIBUICOES ==="
x = 10
y = x + 1
z = y * 2
mostre x                           # 10
mostre y                           # 11
mostre z                           # 22

# ------------------------------------------------------------------
# 10. EXPRESSÕES UNÁRIAS
# ------------------------------------------------------------------
mostre "=== 10. OPERADORES UNARIOS ==="
mostre -(5 + 3)                    # -8
mostre nao verdadeiro               # False
mostre nao (10 > 5)                # False
